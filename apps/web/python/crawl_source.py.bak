import asyncio
import json
import random
import re
from urllib.parse import urljoin, urlparse

from bs4 import BeautifulSoup
from crawl4ai import AsyncWebCrawler
from crawl4ai import CrawlerRunConfig


USER_AGENTS = [
    "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)",
    "Mozilla/5.0 (Windows NT 10.0; Win64; x64)",
    "Mozilla/5.0 (X11; Linux x86_64)",
]

from urllib.parse import urlsplit, urlunsplit

def canonical_url(url: str) -> str:
    parts = urlsplit(url)
    # drop query + fragment
    return urlunsplit((parts.scheme, parts.netloc, parts.path, "", ""))

def domain_of(url: str) -> str:
    return urlparse(url).netloc

async def polite_delay(min_s: float, max_s: float):
    await asyncio.sleep(random.uniform(min_s, max_s))

import re

def extract_profile_generic(html: str, url: str):
    soup = BeautifulSoup(html or "", "lxml")
    raw_text = soup.get_text(separator=" ", strip=True)
    lower = raw_text.lower()
    if "javascript is disabled" in lower or "enable javascript" in lower:
        return None

    h1 = soup.find("h1")
    name = h1.get_text(" ", strip=True) if h1 else None

    # headline: prefer first h2, else meta description
    h2 = soup.find("h2")
    headline = h2.get_text(" ", strip=True) if h2 else None
    if not headline:
      meta = soup.find("meta", attrs={"name": "description"})
      headline = meta.get("content") if meta and meta.get("content") else None

    # bio: first few meaningful paragraphs
    paras = [p.get_text(" ", strip=True) for p in soup.find_all("p")]
    paras = [p for p in paras if len(p) >= 40]
    bio = " ".join(paras[:4]) if paras else None

    # naive price extraction (good enough for MVP)
    price = None
    m = re.search(r'(\$|US\$|USD)\s?\d+(\.\d+)?', raw_text)
    if m:
      price = m.group(0)

    # naive location extraction (optional)
    location = None
    loc = re.search(r'(Seoul|Korea|South Korea|Japan|Tokyo|Hong Kong|Singapore)', raw_text, re.IGNORECASE)
    if loc:
      location = loc.group(0)

    return {
        "source_url": canonical_url(url),
        "source_domain": domain_of(url),
        "name": name,
        "headline": headline,
        "bio": bio,
        "subjects": [],
        "languages": [],
        "price": price,
        "location": location,
        "raw_text": raw_text,
        "metadata": {"extractor": "generic_v2"}
    }

from bs4 import BeautifulSoup

async def discover_profile_urls(crawler, start_url: str, profile_regex: str, max_profiles: int):
    run_cfg = CrawlerRunConfig(
        # wait until the JS-rendered page has tutor links in the DOM
        wait_for="css:main",
        # a little extra time for dynamic content
        wait_for_timeout=15000,
        page_timeout=60000,
        # optionally scroll a bit to trigger lazy-loading
        js_code="""
          window.scrollTo(0, document.body.scrollHeight);
          await new Promise(r => setTimeout(r, 1500));
          window.scrollTo(0, document.body.scrollHeight);
          await new Promise(r => setTimeout(r, 1500));
        """
    )

    page = await safe_arun(crawler, start_url, run_cfg, timeout_sec=70)
    if not page:
        return []
    html = page.html or ""

    soup = BeautifulSoup(html, "lxml")
    links = [a.get("href") for a in soup.find_all("a") if a.get("href")]
    abs_links = [canonical_url(urljoin(start_url, href)) for href in links]

    pat = re.compile(profile_regex)
    candidates = [u for u in abs_links if pat.search(u)]

    # dedupe
    seen = set()
    out = []
    for u in candidates:
        if u in seen:
            continue
        seen.add(u)
        out.append(u)
        if len(out) >= max_profiles:
            break

    print(f"Discovered {len(out)} candidate profile URLs")
    print("Sample URLs:", out[:10])
    return out

async def safe_arun(crawler, url: str, config: CrawlerRunConfig, timeout_sec: int = 70):
    try:
        return await asyncio.wait_for(crawler.arun(url=url, config=config), timeout=timeout_sec)
    except asyncio.TimeoutError:
        print(f"[TIMEOUT] {url}")
        return None
    except Exception as e:
        print(f"[ERROR] {url} -> {e}")
        return None
    
async def crawl_source(key: str, start_urls, profile_regex: str, max_profiles: int, delay_min: float, delay_max: float, out_path: str):
    results = []
    async with AsyncWebCrawler(user_agent=random.choice(USER_AGENTS)) as crawler:
        all_profiles = []
        for start in start_urls:
            urls = await discover_profile_urls(crawler, start, profile_regex, max_profiles)
            all_profiles.extend(urls)

        # dedupe
        seen = set()
        profile_urls = []
        for u in all_profiles:
            if u in seen:
                continue
            seen.add(u)
            profile_urls.append(u)
            if len(profile_urls) >= max_profiles:
                break
        profile_cfg = CrawlerRunConfig(
                    wait_for="css:h1",
                    page_timeout=60000,
                    js_code="""
                    // small scroll to trigger lazy-load
                    window.scrollTo(0, document.body.scrollHeight);
                    await new Promise(r => setTimeout(r, 1500));
                    """
                )

        print(f"[{key}] Discovered {len(profile_urls)} profile URLs")

        with open(out_path, "w", encoding="utf-8") as f:
            for i, url in enumerate(profile_urls, start=1):
                await polite_delay(delay_min, delay_max)

                try:
                    page = await crawler.arun(url=url, config=profile_cfg)
                except Exception as e:
                    print(f"[SKIP_WAIT_FAIL] {url} -> {e}")
                    continue

                page = await safe_arun(crawler, url, profile_cfg, timeout_sec=70)
                if not page:
                    continue
                item = extract_profile_generic(page.html or "", url)
                if not item:
                    print(f"[SKIP] noscript/blocked: {url}")
                    continue
                f.write(json.dumps(item, ensure_ascii=False) + "\n")
                print(f"[{key}] [{i}/{len(profile_urls)}] wrote {url}")

    print(f"[{key}] Done -> {out_path}")

async def main():
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("--source_key", required=True)
    args = parser.parse_args()

    cfg = json.load(open("crawling/sources.json", "r", encoding="utf-8"))
    src = next((s for s in cfg["sources"] if s["key"] == args.source_key), None)
    if not src:
        raise SystemExit(f"Source key not found: {args.source_key}")

    out_path = f"tmp/{src['key']}.ndjson"
    await crawl_source(
        key=src["key"],
        start_urls=src["start_urls"],
        profile_regex=src["profile_url_regex"],
        max_profiles=int(src.get("max_profiles", 30)),
        delay_min=float(src.get("delay_min_sec", 3)),
        delay_max=float(src.get("delay_max_sec", 5)),
        out_path=out_path
    )

if __name__ == "__main__":
    asyncio.run(main())
