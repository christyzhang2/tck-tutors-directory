generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Mentor {
  id                String   @id @default(cuid())
  name              String
  headline          String?
  bio               String?
  city              String?
  country           String?
  timezone          String?
  qualifications    String?
  mode              String?
  culturalBridgeFit String?
  teenRapport       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  mentorTags MentorTag[]
}

model Tag {
  id        String   @id @default(cuid())
  type      TagType
  label     String
  createdAt DateTime @default(now())

  mentorTags MentorTag[]

  @@unique([type, label])
}

model MentorTag {
  mentorId String
  tagId    String

  mentor Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mentorId, tagId])
}

enum TagType {
  SUBJECT
  LANGUAGE
  CURRICULUM
  HERITAGE
  TCK_MARKER
  INTEREST
}

enum StageStatus {
  NEW
  REVIEWING
  APPROVED
  REJECTED
}

model RawSource {
  id        String   @id @default(cuid())
  url       String   @unique
  domain    String
  title     String?
  crawledAt DateTime @default(now())

  stagedMentors StagedMentor[]
}

model StagedMentor {
  id          String      @id @default(cuid())
  status      StageStatus @default(NEW)

  // extracted fields (editable during review)
  name        String?
  headline    String?
  bio         String?
  city        String?
  country     String?
  timezone    String?

  // raw extraction payload for debugging + re-processing
  rawJson     Json

  // provenance
  sourceId    String
  source      RawSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // optional dedupe hints
  fingerprint String? @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([sourceId])
}
